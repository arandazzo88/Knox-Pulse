rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Community-submitted events — publicly readable, writable (create/update/delete)
    // TODO: lock down with Firebase Auth once auth is implemented
    match /communityEvents/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Admin-managed custom listings
    match /listings/{docId} {
      allow read: if true;
      allow write: if false;  // admin writes go through server functions
    }

    // Reviews — anyone can read and create, no editing/deleting
    match /reviews/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // Photos — anyone can read and create
    match /photos/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // Edit requests — anyone can read and create
    match /editRequests/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // Everything else — deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
